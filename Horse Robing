#include <bits/stdc++.h>
using namespace std;
int main() {
#ifndef ONLINE_JUDGE
    freopen("input.txt", "r", stdin);
    freopen("output.txt", "w", stdout);
#endif
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;
    cin >> t;
    while(t--) {
        long long n, k, x;
        cin >> n >> k >> x;
        long long mn = k * (k + 1) / 2;
        long long mx = k * (2 * n - k + 1) / 2;
        if(x >= mn && x <= mx)
            cout << "YES\n";
        else
            cout << "NO\n";
    }
    return 0;
}

